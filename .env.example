# ════════════════════════════════════════════════════════════════════
#  ICAI SPOM Slot Monitor — Environment Variables
#  Copy this file to ".env" and fill in your values.
#  Lines starting with # are comments and are ignored.
# ════════════════════════════════════════════════════════════════════


# ── TELEGRAM (required) ──────────────────────────────────────────────
# 1. Open Telegram, search for @BotFather
# 2. Send /newbot and follow the prompts
# 3. Copy the token (looks like: 1234567890:ABCdefGHIjklmNOpqrSTUvwxYZ)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Your Telegram chat ID
# Get it by: (a) starting a chat with your bot, then
#            (b) messaging @userinfobot  → it replies with "Id: 123456789"
# For multiple recipients, separate IDs with commas: 123456,789012
TELEGRAM_CHAT_IDS=YOUR_CHAT_ID_HERE


# ── ICAI LOGIN (optional) ─────────────────────────────────────────────
# Fill these in ONLY if the SPOM page redirects to a login form.
# Leave blank if the Centre Availability page opens without login.
ICAI_USERNAME=
ICAI_PASSWORD=


# ── BROWSER ───────────────────────────────────────────────────────────
# true  → invisible Chrome (recommended for servers and scheduled jobs)
# false → visible Chrome (useful when debugging locally)
HEADLESS=true


# ── MONITORING CADENCE ────────────────────────────────────────────────
# How many seconds between each full check cycle.
# 180 = 3 minutes  |  300 = 5 minutes  |  120 = 2 minutes
POLL_INTERVAL_SEC=180

# How many extra months forward to scan in the calendar.
# 3 = current month + next 3 months
MONTHS_TO_CHECK=3

# Max retries if a scrape attempt fails
MAX_RETRIES=3

# Seconds to wait between retry attempts
RETRY_DELAY_SEC=15

# Seconds to wait for a page element before timing out
PAGE_TIMEOUT_SEC=25


# ── ALERT BEHAVIOUR ───────────────────────────────────────────────────
# Send an alert on the very first run if slots are already open?
# true = yes (recommended so you don't miss slots that exist right now)
ALERT_ON_FIRST_RUN=true

# Send a "bot is running" ping to Telegram when the monitor starts?
SEND_STARTUP_MESSAGE=false


# ── ADVANCED ─────────────────────────────────────────────────────────
# Only change if ICAI moves the portal URL
# SPOM_URL=https://spmt.icai.org/ICAI/LoginAction_showSlotDetails.action

# Override the state file location (default: state.json in project root)
# STATE_FILE=state.json
